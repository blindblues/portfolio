---
import Layout from "../layouts/Layout.astro";
import Scene3D from "../components/Scene3D.tsx";
import PortfolioContent from "../components/PortfolioContent.tsx";
---

<Layout
	title="Emanuele Greco"
	description="High-end 3D portfolio of Emanuele Greco, Digital Artist & Web Developer."
>
	<main>
		<div id="intro-container">
			<Scene3D client:only="react" />
		</div>
		<div id="content-container" style="opacity: 0; pointer-events: none;">
			<PortfolioContent client:only="react" />
		</div>
	</main>
</Layout>

<script>
	// Force scroll to top on reload and disable scrolling during intro
	if (typeof history !== "undefined" && "scrollRestoration" in history) {
		history.scrollRestoration = "manual";
	}
	window.scrollTo(0, 0);
	document.body.style.overflow = "hidden";

	let transitionTimeout: any;

	function performTransition(isSkip = false) {
		if (transitionTimeout) clearTimeout(transitionTimeout);

		const intro = document.getElementById("intro-container");
		const sceneWrapper = document.getElementById("scene-3d-wrapper");
		const content = document.getElementById("content-container");

		if (intro && sceneWrapper && content) {
			// Re-enable scrolling and pointer events
			document.body.style.overflow = "auto";
			content.style.pointerEvents = "auto";

			if (isSkip) {
				// Immediate switch if clicked
				intro.remove();
				content.style.opacity = "1";
				window.dispatchEvent(new CustomEvent("modelMoveUpStart"));
			} else {
				// 1. Reveal content container by setting opacity (it's already mounted)
				content.style.transition = "opacity 1s ease-in";
				content.style.opacity = "1";

				// 2. Fade out black background of the ASCII scene to reveal the content
				sceneWrapper.style.backgroundColor = "transparent";

				intro.style.pointerEvents = "none";
				window.dispatchEvent(new CustomEvent("modelMoveUpStart"));

				// 3. Start ASCII character disintegration effect
				window.dispatchEvent(new CustomEvent("asciiDisintegrate"));

				// 4. Remove the intro container after the effect finishes (approx 1s)
				setTimeout(() => {
					intro.remove();
				}, 1500);
			}
		}
	}

	// Wait 6.5 seconds before starting the background fade
	transitionTimeout = setTimeout(() => performTransition(false), 6500);

	const introDiv = document.getElementById("intro-container");
	if (introDiv) {
		introDiv.addEventListener("click", () => performTransition(true));
		introDiv.style.cursor = "pointer";
	}
</script>

<style is:global>
	#intro-container {
		position: fixed;
		inset: 0;
		z-index: 100;
		width: 100%;
		height: 100vh;
	}

	main {
		width: 100%;
		min-height: 100vh;
		background: #000000;
		overflow-x: hidden;
	}
	.hidden {
		display: none !important;
	}
	.opacity-0 {
		opacity: 0;
	}
</style>
