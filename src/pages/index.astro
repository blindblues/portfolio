---
import Layout from "../layouts/Layout.astro";
import Scene3D from "../components/Scene3D.tsx";
import PortfolioContent from "../components/PortfolioContent.tsx";
---

<Layout
	title="Emanuele Greco"
	description="High-end 3D portfolio of Emanuele Greco, Digital Artist & Web Developer."
>
	<main>
		<div id="intro-container">
			<Scene3D client:only="react" />
			<div id="scroll-arrow">
				<svg
					width="24"
					height="24"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="1.5"
					stroke-linecap="round"
					stroke-linejoin="round"
				>
					<path d="M7 10l5 5 5-5"></path>
				</svg>
			</div>
		</div>
		<div id="content-container" style="opacity: 0; pointer-events: none;">
			<PortfolioContent client:only="react" />
		</div>
	</main>
</Layout>

<script>
	import { gsap } from "gsap";

	// Force scroll to top on reload and disable scrolling during intro
	if (typeof history !== "undefined" && "scrollRestoration" in history) {
		history.scrollRestoration = "manual";
	}
	window.scrollTo(0, 0);
	document.documentElement.style.overflow = "hidden";
	document.body.style.overflow = "hidden";

	let isTransitioned = false;

	function performTransition() {
		if (isTransitioned) return;
		isTransitioned = true;

		const intro = document.getElementById("intro-container");
		const content = document.getElementById("content-container");

		if (intro && content) {
			// Don't enable scroll yet, just reveal content opacity
			content.style.opacity = "1";

			// Hide arrow
			const arrow = document.getElementById("scroll-arrow");
			if (arrow) gsap.to(arrow, { opacity: 0, duration: 0.3 });

			// Swipe Reveal Animation
			const tl = gsap.timeline({
				onComplete: () => {
					// Re-enable scrolling and pointer events ONLY when intro is gone
					document.documentElement.style.overflow = "auto";
					document.body.style.overflow = "auto";
					content.style.pointerEvents = "auto";
					intro.remove();
				},
			});

			window.dispatchEvent(new CustomEvent("modelMoveUpStart"));

			tl.to(intro, {
				yPercent: -100,
				duration: 1.5,
				ease: "expo.inOut",
			});
		}
	}

	// Trigger transition on first scroll or click
	window.addEventListener(
		"wheel",
		(e) => {
			if (e.deltaY > 5) performTransition();
		},
		{ passive: true },
	);

	window.addEventListener(
		"touchstart",
		(e) => {
			const startY = e.touches[0].pageY;
			const handleTouchMove = (moveEvent: TouchEvent) => {
				if (startY - moveEvent.touches[0].pageY > 10) {
					performTransition();
					window.removeEventListener("touchmove", handleTouchMove);
				}
			};
			window.addEventListener("touchmove", handleTouchMove, {
				passive: true,
			});
		},
		{ passive: true },
	);

	const introDiv = document.getElementById("intro-container");
	if (introDiv) {
		introDiv.addEventListener("click", () => performTransition());
		introDiv.style.cursor = "pointer";
	}

	// Floating arrow animation
	gsap.to("#scroll-arrow", {
		y: 10,
		duration: 1.5,
		repeat: -1,
		yoyo: true,
		ease: "power1.inOut",
	});
</script>

<style is:global>
	#intro-container {
		position: fixed;
		inset: 0;
		z-index: 100;
		width: 100%;
		height: 100vh;
		background: #000;
		overflow: hidden;
	}

	#scroll-arrow {
		position: absolute;
		bottom: 40px;
		left: 50%;
		transform: translateX(-50%);
		color: #ffffff;
		z-index: 102;
		opacity: 0.6;
		pointer-events: none;
	}

	main {
		width: 100%;
		min-height: 100vh;
		background: #000000;
		overflow-x: hidden;
	}
	.hidden {
		display: none !important;
	}
	.opacity-0 {
		opacity: 0;
	}
</style>
